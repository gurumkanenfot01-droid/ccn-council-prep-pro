# Copy this file to server/.env and fill in your own values.
# Never commit server/.env or paste real keys into chat, issues, or PRs.

# Stripe Dashboard -> Developers -> API keys (use the test mode secret key
# while developing, it starts with sk_test_).
STRIPE_SECRET_KEY=

# Optional, only needed if you wire up the /api/stripe/webhook endpoint to a
# real Stripe webhook (Dashboard -> Developers -> Webhooks -> signing secret,
# starts with whsec_). Not required for the basic checkout flow.
STRIPE_WEBHOOK_SECRET=

# The origin the frontend is actually served from. Stripe redirects the
# browser here after checkout, so it must be reachable by the customer —
# not the API server's own origin. Defaults to the Vite dev server.
CLIENT_URL=http://localhost:5183

# Port this server listens on.
PORT=5185
